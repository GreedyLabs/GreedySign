{
  "name": "@greedylabs/greedysign-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "tsx src/db/init.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@greedylabs/greedysign-shared": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.45.0",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.14",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "sharp": "^0.33.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.2",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2"
  }
}
