{
  "name": "@greedylabs/greedysign",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "build:shared": "pnpm --filter '@greedylabs/greedysign-shared' build",
    "db:init": "pnpm --filter '@greedylabs/greedysign-api' db:init",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,css,json}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
